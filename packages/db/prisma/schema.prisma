generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DeveloperAccount {
  id           String             @id @default(cuid())
  email        String             @unique
  passwordHash String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  sessions     DeveloperSession[]
  apps         App[]
}

model DeveloperSession {
  id        String           @id @default(cuid())
  developerId String
  tokenHash String           @unique
  expiresAt DateTime
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  developer DeveloperAccount @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@index([developerId])
}

model UserIdentity {
  id            String             @id @default(cuid())
  issuer        String
  subject       String
  email         String
  displayName   String?
  salt          String
  walletAddress String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  developerProfile DeveloperProfile?
  sessions      UserSession[]

  @@unique([issuer, subject])
}

model DeveloperProfile {
  id             String       @id @default(cuid())
  userIdentityId String       @unique
  email          String       @unique
  displayName    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  userIdentity   UserIdentity @relation(fields: [userIdentityId], references: [id], onDelete: Cascade)
  apps           App[]
}

model AuthLoginRequest {
  id          String   @id @default(cuid())
  clientKind  String
  clientId    String
  appId       String?
  state       String
  oauthState  String?  @unique
  redirectUri String
  nonce       String?
  extendedEphemeralPublicKey String?
  maxEpoch    Int?
  jwtRandomness String?
  zkLoginProofInputsJson String?
  status      String
  authCode    String?  @unique
  userIdentityId String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientKind, clientId])
  @@index([userIdentityId])
}

model UserSession {
  id             String       @id @default(cuid())
  userIdentityId String
  clientKind     String
  clientId       String
  appId          String?
  walletAddress  String
  chainId        String
  tokenHash      String       @unique
  zkLoginMaxEpoch Int?
  zkLoginProofInputsJson String?
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  userIdentity   UserIdentity @relation(fields: [userIdentityId], references: [id], onDelete: Cascade)

  @@index([userIdentityId])
  @@index([clientKind, clientId])
}

model App {
  id               String             @id @default(cuid())
  developerId      String?
  developerProfileId String?
  name             String
  slug             String             @unique
  allowedChainId   String
  authProvider     String
  creditsPerUsd    Int                @default(100)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  developer        DeveloperAccount?  @relation(fields: [developerId], references: [id], onDelete: Cascade)
  developerProfile DeveloperProfile?  @relation(fields: [developerProfileId], references: [id], onDelete: SetNull)
  actions          ManagedAction[]
  sponsorWallets   SponsorWallet[]
  registeredPrograms RegisteredProgram[]
  checkoutSessions CheckoutSession[]
  creditLedgerEntries CreditLedgerEntry[]
  pendingActionReservations PendingActionReservation[]
  sponsorGasCoinLocks SponsorGasCoinLock[]
  transactionRecords TransactionRecord[]

  @@index([developerId])
  @@index([developerProfileId])
}

model ManagedAction {
  id           String   @id @default(cuid())
  appId        String
  actionType   String
  priceCredits Int
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  app          App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([appId, actionType])
  @@index([appId])
}

model SponsorWallet {
  id              String   @id @default(cuid())
  appId           String
  chainFamily     String
  network         String
  address         String
  encryptedSecret String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  app             App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([appId, chainFamily, network])
  @@index([appId])
}

model RegisteredProgram {
  id                   String   @id @default(cuid())
  appId                String
  chainFamily          String
  network              String
  packageId            String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  app                  App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([appId, chainFamily, network])
  @@index([appId])
}

model CheckoutSession {
  id                 String   @id @default(cuid())
  appId              String
  walletAddress      String
  chainId            String
  usdAmount          Int
  creditsPerUsd      Int
  credits            Int
  status             String
  successRedirectUrl String
  cancelRedirectUrl  String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  app                App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId])
  @@index([walletAddress])
  @@index([status])
}

model CreditLedgerEntry {
  id            String   @id @default(cuid())
  appId         String
  walletAddress String
  chainId       String
  deltaCredits  Int
  reason        String
  referenceType String
  referenceId   String
  createdAt     DateTime @default(now())
  app           App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([appId, referenceType, referenceId, reason])
  @@index([appId, walletAddress])
}

model PendingActionReservation {
  id               String   @id @default(cuid())
  appId            String
  walletAddress    String
  chainId          String
  actionType       String
  status           String
  metadataJson     String?
  username         String?
  message          String?
  creditsReserved  Int
  transactionBytes String
  sponsorSignature String
  sponsorAddress   String
  expiresAt        DateTime
  submittedDigest  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  app              App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  gasCoinLock      SponsorGasCoinLock?

  @@index([appId, walletAddress])
  @@index([status, expiresAt])
}

model SponsorGasCoinLock {
  id            String   @id @default(cuid())
  appId         String
  reservationId String   @unique
  objectId      String
  version       String
  digest        String
  status        String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  app           App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  reservation   PendingActionReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([appId, status])
}

model TransactionRecord {
  id             String    @id @default(cuid())
  appId          String
  walletAddress  String
  chainId        String
  actionType     String
  metadataJson   String?
  username       String?
  message        String?
  digest         String
  explorerUrl    String
  status         String
  confirmedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  app            App       @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([appId, digest])
  @@index([appId, createdAt])
}
